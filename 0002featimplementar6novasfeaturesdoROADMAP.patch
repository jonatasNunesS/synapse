+                      >
+                        {evento.concluido
+                          ? <CheckCircle2 className="h-5 w-5 text-emerald-400" />
+                          : <Circle className="h-5 w-5" />
+                        }
+                      </button>
+                    </div>
+                    <div
+                      className="w-1 self-stretch rounded-full flex-shrink-0"
+                      style={{ backgroundColor: evento.cor, minHeight: "20px" }}
+                    />
+                    <div className="flex-1 min-w-0">
+                      <div className="flex items-center gap-2 flex-wrap">
+                        <p className={`text-sm font-medium ${evento.concluido ? "line-through text-zinc-500" : "text-white"}`}>
+                          {evento.titulo}
+                        </p>
+                        <span
+                          className="text-xs px-1.5 py-0.5 rounded-full"
+                          style={{ backgroundColor: `${evento.cor}25`, color: evento.cor }}
+                        >
+                          {TIPO_EVENTO_LABELS[evento.tipo]}
+                        </span>
+                      </div>
+                      <div className="flex items-center gap-3 mt-1 text-xs text-zinc-500 flex-wrap">
+                        {!evento.dia_inteiro && (
+                          <span className="flex items-center gap-1">
+                            <Clock className="h-3 w-3" />
+                            {formatTime(evento.data_inicio)}
+                            {evento.data_fim && ` — ${formatTime(evento.data_fim)}`}
+                          </span>
+                        )}
+                        {evento.dia_inteiro && <span>Dia inteiro</span>}
+                        {evento.local && (
+                          <span className="flex items-center gap-1">
+                            <MapPin className="h-3 w-3" />
+                            {evento.local}
+                          </span>
+                        )}
+                      </div>
+                      {evento.descricao && (
+                        <p className="text-xs text-zinc-500 mt-1 truncate">{evento.descricao}</p>
+                      )}
+                    </div>
+                    <div className="flex items-center gap-1 flex-shrink-0">
+                      <button
+                        onClick={() => { setEditando(evento); setShowForm(true); }}
+                        className="p-1 rounded text-zinc-500 hover:text-violet-400 hover:bg-violet-500/10 transition-colors"
+                      >
+                        <Pencil className="h-3.5 w-3.5" />
+                      </button>
+                      <button
+                        onClick={() => deletar(evento.id)}
+                        className="p-1 rounded text-zinc-500 hover:text-red-400 hover:bg-red-500/10 transition-colors"
+                      >
+                        <Trash2 className="h-3.5 w-3.5" />
+                      </button>
+                    </div>
+                  </div>
+                ))
+              )}
+            </div>
+          </div>
+        </div>
+      </div>
+
+      {showForm && (
+        <EventoFormModal
+          evento={editando}
+          dataSelecionada={diaSelecionado}
+          onClose={() => { setShowForm(false); setEditando(null); }}
+          onSave={async (dados) => {
+            if (editando) {
+              await atualizar(editando.id, dados);
+            } else {
+              await criar(dados);
+            }
+          }}
+        />
+      )}
+    </div>
+  );
+}
