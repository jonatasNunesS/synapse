+function formatTime(iso: string) {
+  const d = new Date(iso);
+  return d.toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" });
+}
+
+function formatDate(iso: string) {
+  const d = new Date(iso);
+  return d.toLocaleDateString("pt-BR", { day: "2-digit", month: "short" });
+}
+
+function isoDate(date: Date) {
+  return date.toISOString().split("T")[0];
+}
+
+// ── EventoForm Modal ────────────────────────────────────────
+
+function EventoFormModal({
+  evento,
+  dataSelecionada,
+  onClose,
+  onSave,
+}: {
+  evento?: Evento | null;
+  dataSelecionada?: Date;
+  onClose: () => void;
+  onSave: (dados: EventoFormData) => Promise<void>;
+}) {
+  const defaultDate = dataSelecionada || new Date();
+  const defaultDateStr = `${isoDate(defaultDate)}T09:00`;
+
+  const [titulo, setTitulo] = useState(evento?.titulo || "");
+  const [descricao, setDescricao] = useState(evento?.descricao || "");
+  const [tipo, setTipo] = useState<Evento["tipo"]>(evento?.tipo || "reuniao");
+  const [cor, setCor] = useState(evento?.cor || TIPO_EVENTO_CORES[tipo]);
+  const [dataInicio, setDataInicio] = useState(evento?.data_inicio ? evento.data_inicio.slice(0, 16) : defaultDateStr);
+  const [dataFim, setDataFim] = useState(evento?.data_fim ? evento.data_fim.slice(0, 16) : "");
+  const [local, setLocal] = useState(evento?.local || "");
+  const [diaInteiro, setDiaInteiro] = useState(evento?.dia_inteiro || false);
+  const [lembrete, setLembrete] = useState(evento?.lembrete_minutos ? String(evento.lembrete_minutos) : "");
+  const [loading, setLoading] = useState(false);
+  const [erro, setErro] = useState<string | null>(null);
+
+  const CORES = ["#6D28D9", "#2563EB", "#059669", "#D97706", "#DC2626", "#7C3AED", "#0891B2", "#84CC16"];
+
+  const handleTipoChange = (t: Evento["tipo"]) => {
+    setTipo(t);
+    setCor(TIPO_EVENTO_CORES[t]);
+  };
+
+  const handleSubmit = async (e: React.FormEvent) => {
+    e.preventDefault();
+    if (!titulo.trim()) { setErro("Título é obrigatório."); return; }
+    if (!dataInicio) { setErro("Data de início é obrigatória."); return; }
+    setLoading(true);
+    setErro(null);
+    try {
+      await onSave({
+        titulo: titulo.trim(),
+        descricao,
+        tipo,
+        cor,
+        data_inicio: diaInteiro ? `${dataInicio.slice(0, 10)}T00:00:00` : dataInicio,
+        data_fim: dataFim ? (diaInteiro ? `${dataFim.slice(0, 10)}T23:59:59` : dataFim) : null,
+        dia_inteiro: diaInteiro,
+        local,
+        lembrete_minutos: lembrete ? parseInt(lembrete) : null,
+      });
+      onClose();
+    } catch {
+      setErro("Erro ao salvar evento.");
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  return (
+    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
+      <div className="bg-[#0f1117] border border-white/10 rounded-2xl shadow-2xl w-full max-w-md max-h-[90vh] overflow-y-auto">
+        <div className="flex items-center justify-between px-6 py-4 border-b border-white/10">
+          <h3 className="font-semibold text-white">{evento ? "Editar Evento" : "Novo Evento"}</h3>
+          <button onClick={onClose} className="text-zinc-400 hover:text-white p-1 rounded">
+            <X className="h-5 w-5" />
+          </button>
+        </div>
+        <form onSubmit={handleSubmit} className="p-6 space-y-4">
+          <div>
+            <label className="block text-xs font-medium text-zinc-400 mb-1">Título *</label>
+            <input
+              value={titulo}
+              onChange={(e) => setTitulo(e.target.value)}
+              placeholder="Nome do evento"
+              className="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-sm text-white outline-none focus:border-violet-500/50"
+            />
+          </div>
+
+          <div className="grid grid-cols-2 gap-3">
+            <div>
+              <label className="block text-xs font-medium text-zinc-400 mb-1">Tipo</label>
+              <select
+                value={tipo}
+                onChange={(e) => handleTipoChange(e.target.value as Evento["tipo"])}
+                className="w-full bg-zinc-900 border border-white/10 rounded-lg px-3 py-2 text-sm text-white outline-none focus:border-violet-500/50"
+              >
+                {Object.entries(TIPO_EVENTO_LABELS).map(([k, v]) => (
+                  <option key={k} value={k}>{v}</option>
+                ))}
+              </select>
+            </div>
+            <div>
+              <label className="block text-xs font-medium text-zinc-400 mb-2">Cor</label>
+              <div className="flex gap-1.5 flex-wrap">
+                {CORES.map((c) => (
+                  <button
+                    key={c}
+                    type="button"
+                    onClick={() => setCor(c)}
+                    className={`w-6 h-6 rounded-full border-2 transition-all ${cor === c ? "border-white scale-110" : "border-transparent"}`}
+                    style={{ backgroundColor: c }}
+                  />
+                ))}
+              </div>
+            </div>
+          </div>
+
+          <div className="flex items-center gap-2">
+            <input
+              type="checkbox"
+              id="dia_inteiro"
+              checked={diaInteiro}
+              onChange={(e) => setDiaInteiro(e.target.checked)}
+              className="rounded"
