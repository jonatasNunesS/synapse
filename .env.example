# ════════════════════════════════════════════════════════════
# Synapse - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0, backend
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Banco de Dados (PostgreSQL) ────────────────────────────
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse_dev_2026
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://synapse:synapse_dev_2026@postgres:5432/synapse

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── CORS ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=

# ── IA (Groq) - Apenas M9 ─────────────────────────────────
GROQ_API_KEY=

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://backend:8000/api
NEXT_PUBLIC_APP_NAME=Synapse
# URL base do backend para o proxy do Next.js
# Docker Compose: http://backend:8000 | Desenvolvimento local: http://backend:8000
NEXT_PUBLIC_BACKEND_URL=http://backend:8000
